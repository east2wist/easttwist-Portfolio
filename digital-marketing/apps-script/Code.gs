const SPREADSHEET_ID='1ugES8hQ4tiqcz7ja3OiiiJ0lCdj2HtSGwHNC5gAq5ME';const LEADS_SHEET='Leads';function doPost(e){try{const p=JSON.parse(e.postData.contents||'{}');const s=SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(LEADS_SHEET);if(!s)throw new Error('Leads sheet not found');const h=s.getRange(1,1,1,s.getLastColumn()).getValues()[0];const v={'Lead ID':Utilities.getUuid(),'Submitted At':new Date(),'Name':c(p.name),'Phone':c(p.phone),'Business':c(p.business),'Service':c(p.service),'Monthly Budget':c(p.budget),'Message':c(p.message),'Status':'New','Lead Value':'','Currency':'SAR','GCLID':c(p.gclid),'GBRAID':c(p.gbraid),'WBRAID':c(p.wbraid),'UTM Source':c(p.utm_source),'UTM Medium':c(p.utm_medium),'UTM Campaign':c(p.utm_campaign),'UTM Term':c(p.utm_term),'UTM Content':c(p.utm_content),'Landing Page':c(p.landing_page),'Referrer':c(p.referrer),'Event ID':c(p.event_id),'User Agent':c(p.user_agent),'Language':c(p.language),'Notes':''};s.appendRow(h.map(x=>v[x]!==undefined?v[x]:''));return out({ok:true,lead_id:v['Lead ID']})}catch(err){return out({ok:false,error:String(err)})}}function doGet(){return out({ok:true,service:'East Twist lead endpoint'})}function c(v){return String(v||'').trim().slice(0,5000)}function out(v){return ContentService.createTextOutput(JSON.stringify(v)).setMimeType(ContentService.MimeType.JSON)}